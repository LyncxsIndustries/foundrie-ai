# Clerk authentication (Feature 02)
# Obtain these from the Clerk dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Neon Postgres (Feature 03)
# DATABASE_URL is the POOLED runtime connection — it must use the `-pooler` Neon
# endpoint (PgBouncer transaction mode). All application queries use this URL.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# DIRECT_URL is the UNPOOLED connection (no `-pooler`). Used only by the Prisma
# CLI for migrations; runtime code must never use it.
#
# Neon Free tier scales the compute to zero after ~5 min idle. The first
# connection wakes it, which can take longer than Prisma's default 5s connect
# timeout and surface as `P1001: Can't reach database server`. Append
# `connect_timeout=15` to the DIRECT_URL so the CLI waits for the compute to wake.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connect_timeout=15"
