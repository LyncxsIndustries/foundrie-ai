# AI provider API keys (Feature 05 - AI Rotation Engine)
# The rotation engine routes every AI call through provider adapters in
# lib/ai/providers. A provider with no key is treated as unavailable and skipped
# (it does not count as a failed attempt), so the engine degrades gracefully
# when only some keys are present. Build and tests do not require real keys.
#
# Anthropic (Claude Sonnet 4): https://console.anthropic.com
# OPTIONAL BUT HIGHLY RECOMMENDED. While the rotation engine will gracefully
# fall back to free providers (like Gemini/DeepSeek) if this is missing,
# Claude Sonnet 4 is Foundrie's primary model for PRO/ENTERPRISE tiers. It
# produces significantly higher quality architecture proposals and feature specs.
# If you leave this blank, the system will still work perfectly using free models.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Google Gemini (gemini-2.5-pro / flash): https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek (deepseek-reasoner=R1 / deepseek-chat=V3): https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Groq (fast llama/gemma inference): https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# OpenRouter (unified fallback access to many models): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Public app URL. Sent by the OpenRouter adapter as HTTP-Referer / X-Title for
# traffic attribution; also used elsewhere as the canonical app origin.
NEXT_PUBLIC_APP_URL=https://foundrieai.com

# Clerk authentication (Feature 02)
# Obtain these from the Clerk dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Clerk webhook signing secret (Feature 04)
# Copy the Signing Secret from the webhook endpoint's settings page in the Clerk
# Dashboard. `verifyWebhook()` reads this exact variable name to validate the
# Svix signature before any user-sync write.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Admin allowlist (Feature 04)
# Comma-separated emails granted v1 admin access (checked by lib/auth/is-admin.ts).
ADMIN_EMAILS="founder@example.com"

# Neon Postgres (Feature 03)
# DATABASE_URL is the POOLED runtime connection — it must use the `-pooler` Neon
# endpoint (PgBouncer transaction mode). All application queries use this URL.
#
# Neon Free tier scales the compute to zero after ~5 min idle. The first
# connection wakes it, which can take longer than Prisma's default 5s connect
# timeout and surface as `P1001: Can't reach database server`. `connect_timeout=15`
# gives the compute time to wake on both the runtime and CLI connections.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connect_timeout=15"
# DIRECT_URL is the UNPOOLED connection (no `-pooler`). Used only by the Prisma
# CLI for migrations; runtime code must never use it.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connect_timeout=15"

# Vercel Blob Storage (Feature 07 - Research Library)
# Used for uploading project references, screenshots, and frame ZIPs.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx

# Research Connectors (Feature 09)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx
# Obscura is OPTIONAL. Foundrie will auto-detect the local `obscura` binary
# installed at ~/.local/bin/obscura or in your PATH. Only set OBSCURA_ENDPOINT
# if you are explicitly running `obscura serve` as a remote HTTP service.
OBSCURA_ENDPOINT=http://localhost:9222/scrape
